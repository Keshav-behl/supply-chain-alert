# Supply Chain Alert — Environment Variables
# Copy this file to .env and fill in your real keys
# NEVER commit .env to GitHub

# ── Data Sources ──────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
# Get free key at: https://newsapi.org/register

OPENWEATHER_API_KEY=your_openweather_key_here
# Get free key at: https://openweathermap.org/api

# ── Database ──────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
# Get free project at: https://supabase.com

# ── WhatsApp / Twilio ─────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Twilio sandbox number — free to test

# ── LLM ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get key at: https://console.anthropic.com

# ── Alert Config ──────────────────────────────
RISK_SCORE_THRESHOLD=25
ALERT_PHONE_NUMBER=whatsapp:+91XXXXXXXXXX

